{
  "name": "gdbb-platform",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:stack": "node ./scripts/dev-stack.mjs",
    "dev:web": "pnpm -C apps/web dev",
    "dev:worker": "pnpm -C apps/worker dev",
    "snapshot:save": "node ./scripts/snapshot-manager.mjs save",
    "snapshot:restore": "node ./scripts/snapshot-manager.mjs restore",
    "snapshot:list": "node ./scripts/snapshot-manager.mjs list",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "engine:dev": "uvicorn app.main:app --reload --port 8000 --app-dir apps/engine",
    "engine:test": "python -m pytest apps/engine/tests",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "eslint": "^8.57.1",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}

